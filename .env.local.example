NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email SMTP (Gmail hoặc SMTP khác)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# Thông tin tài khoản ngân hàng nhận thanh toán
BANK_ID=MB
BANK_ACCOUNT=0987654321
BANK_ACCOUNT_NAME=CONG TY TNHH ABC
BANK_TEMPLATE=compact2

# Webhook secret từ SePay
SEPAY_WEBHOOK_SECRET=your_sepay_secret

# URL của website (dùng cho VietQR)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
